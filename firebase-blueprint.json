{
  "entities": {
    "Organization": {
      "title": "Organization",
      "description": "Represents a company or agency using the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "domain": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "settings": {
          "type": "object",
          "properties": {
            "branding": { "type": "object" }
          }
        }
      },
      "required": ["name", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Extended user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "organizationId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "recruiter"] },
        "fullName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "organizationId", "role"]
    },
    "Job": {
      "title": "Job",
      "description": "Represents a job opening with requirements.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "organizationId": { "type": "string" },
        "description": { "type": "string" },
        "requirements": {
          "type": "object",
          "properties": {
            "must_have_skills": { "type": "array", "items": { "type": "string" } },
            "nice_to_have_skills": { "type": "array", "items": { "type": "string" } },
            "min_experience_years": { "type": "number" },
            "required_education": { "type": "string" },
            "location_requirement": { "type": "string" },
            "role_seniority": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] }
      },
      "required": ["title", "createdBy", "createdAt", "organizationId"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "Structured candidate data parsed from a resume and screened for a specific job.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "organizationId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "currentRole": { "type": "string" },
        "currentCompany": { "type": "string" },
        "totalExperience": { "type": "number" },
        "oneLineSummary": { "type": "string" },
        "scorecard": {
          "type": "object",
          "properties": {
            "compositeScore": { "type": "number" },
            "dimensions": {
              "type": "object",
              "properties": {
                "skillsMatch": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } },
                "experienceRelevance": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } },
                "experienceDepth": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } },
                "education": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } },
                "careerTrajectory": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } },
                "cultureFit": { "type": "object", "properties": { "score": { "type": "number" }, "rationale": { "type": "string" } } }
              }
            },
            "skillsGap": {
              "type": "object",
              "properties": {
                "mustHave": { "type": "array" },
                "niceToHave": { "type": "array" }
              }
            },
            "greenFlags": { "type": "array", "items": { "type": "string" } },
            "redFlags": { "type": "array", "items": { "type": "string" } },
            "interviewQuestions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "parsedData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["processed", "shortlisted", "rejected"] },
        "interviewStatus": { "type": "string", "enum": ["none", "invited", "in_progress", "completed", "failed"] },
        "meetLink": { "type": "string" }
      },
      "required": ["jobId", "organizationId", "fullName", "createdAt", "status"]
    },
    "InterviewSession": {
      "title": "InterviewSession",
      "description": "Log of an AI-led interview session.",
      "type": "object",
      "properties": {
        "candidateId": { "type": "string" },
        "jobId": { "type": "string" },
        "organizationId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { 
             "type": "object", 
             "properties": {
                "role": { "type": "string", "enum": ["user", "model", "system"] },
                "text": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" }
             }
          }
        },
        "feedback": {
          "type": "object",
          "properties": {
             "rating": { "type": "number" },
             "summary": { "type": "string" },
             "keyInsights": { "type": "array", "items": { "type": "string" } }
          }
        },
        "startedAt": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" }
      },
      "required": ["candidateId", "jobId", "organizationId", "startedAt"]
    }
  },
  "firestore": {
    "/organizations/{organizationId}": {
      "schema": "Organization",
      "description": "Root collection for organizations."
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and org associations."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Collection of job openings."
    },
    "/candidates/{candidateId}": {
      "schema": "Candidate",
      "description": "Collection of candidates processed for specific jobs."
    },
    "/interviews/{interviewId}": {
      "schema": "InterviewSession",
      "description": "Collection of AI-led interview transcripts."
    }
  }
}
