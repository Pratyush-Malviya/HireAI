# NVIDIA API key for NIM LLM, Riva STT/TTS
NVIDIA_API_KEY="nvapi-..."

# Daily.co API key for room creation and transport
DAILY_API_KEY=""
DAILY_API_URL="https://api.daily.co/v1"

# Bot configuration
BOT_NAME="Lydia"
LLM_MODEL="meta/llama-3.3-70b-instruct"
TTS_VOICE_ID="Magpie-Multilingual.EN-US.Sofia"

# Prompt configuration
SYSTEM_PROMPT_FILE="prompt-vp.txt"
PROMPT_DIR="prompts"

# Tool toggles
TOOL_WEATHER_ENABLED=true
