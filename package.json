    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.17.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.41.0",
