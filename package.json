{
  "name": "hire-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "esbuild api/index.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs --format=cjs --external:msedge-tts --external:canvas --external:@composio/core",
